from toolset OpenMeteoTools use get_weather_by_city

deliberate CheckWeatherDeliberate when >> the user asks for the current weather in a specific city <<:
  mandate:
    >> Extract the city name and use get_weather_by_city to fetch real data.
  __mandate

  @completion: drafted->frozen 
  plan:

    in:
        user_request(required) >> the user prompt <<
    __in

    out:
      weather_report >> a formatted string summarizing the weather data <<
    __out

    body:
      [[city_name] = ""]
      do llm using [ [prompt] = "Extract the city name mentioned in this request. Return only the city name, no extra words. Request: [user_request]" ] producing [ [city_name] ] >> extract only the city name from the user request

      do tool OpenMeteoTools.get_weather_by_city using [[city_name] = [city_name]]
         producing [[weather_data]]

      [[result] = ""]
      if [[weather_data:status] == "success"]:
         [[result] = "Weather in "
                   | [city_name]
                   | ": "
                   | to_str([weather_data:temperature_celsius])
                   | " C, wind "
                   | to_str([weather_data:windspeed_kmh])
                   | " km/h" 
                   ]
      else:
         [[result] = "An error occurred: [wheather_data:error]"]
      __if

      return [result]
    __body
  __plan
__deliberate
